++/**
++ * Projected bike split for the configured race distance, riding the rest of it
++ * at the current Normalized Power on flat road with the calibrated CdA.
++ * Green when under the target split, red when over.
++ */
++@OptIn(ExperimentalGlanceRemoteViewsApi::class)
++class SplitPredictorDataType(private val extensionContext: Ki2ExtensionContext) :
++    DataTypeImpl(extensionContext.extension, "DATATYPE_SPLIT_PREDICTOR") {
++
++    private val glance = GlanceRemoteViews()
++    private var lastRendered: Pair<String, Color?>? = null
