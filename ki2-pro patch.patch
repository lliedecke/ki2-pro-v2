++/**
++ * Carbohydrate pacing coach.
++ *
++ * Tracks ride time against a grams-per-hour target, logs intake from a Di2
++ * switch action, and raises an audio nudge when the rider falls a full
++ * portion behind schedule.
++ */
++class FuelEngine(private val extensionContext: Ki2ExtensionContext) {
++
++    val updates = MutableSharedFlow<Unit>(extraBufferCapacity = 1)
++
++    private val scope = CoroutineScope(Dispatchers.IO + Job())
++
++    private val preferencesConsumer = Consumer<PreferencesView> { preferencesView ->
++        this.preferencesView = preferencesView
++    }
++
++    @Volatile
++    private var preferencesView: PreferencesView? = null
++
++    @Volatile
++    private var elapsedMs: Double = 0.0
++
++    @Volatile
++    var carbsEatenGrams: Double = 0.0
++        private set
++
++    private var lastNudgeTime: Long = 0
++
++    init {
++        extensionContext.serviceClient.registerPreferencesWeakListener(preferencesConsumer)
++
++        scope.launch {
++            extensionContext.karooSystem.streamData(DataType.Type.ELAPSED_TIME)
++                .collect {
++                    elapsedMs = (it as? StreamState.Streaming)?.dataPoint?.singleValue ?: elapsedMs
++                }
++        }
++        scope.launch {
++            extensionContext.karooSystem.streamRideState()
++                .collect { state ->
++                    if (state is RideState.Idle) {
++                        carbsEatenGrams = 0.0
++                        elapsedMs = 0.0
++                        lastNudgeTime = 0
++                        updates.tryEmit(Unit)
++                    }
++                }
++        }
++        scope.launch {
++            while (true) {
++                delay(if (active()) 1000 else 3000)
++                checkNudge()
++                updates.tryEmit(Unit)
++            }
++        }
++    }
++
++    private fun targetGramsPerHour(): Double =
