@@ -125,4 +125,42 @@ public class ShiftingGearingHelper {
         return shiftingInfo == null ? 0 : shiftingInfo.getRearGearMax();
     }
 
+    /**
+     * Rear teeth counts in gear order (element 0 = gear 1, the largest cog).
+     * Respects custom gearing preferences when enabled.
+     */
+    public int[] getRearTeethByGear() {
+        if (customGearing && customGearingRear != null) {
+            return customGearingRear;
+        }
+        if (shiftingInfo == null) {
+            return new int[0];
+        }
+        int gearCount = shiftingInfo.getRearTeethPattern().getGearCount();
+        int[] teethByGear = new int[gearCount];
+        for (int gear = 1; gear <= gearCount; gear++) {
+            teethByGear[gear - 1] = shiftingInfo.getRearTeethPattern().getTeethCount(gear);
+        }
+        return teethByGear;
+    }
+
+    /**
+     * Front teeth counts in gear order (element 0 = gear 1, the smallest ring).
+     * Respects custom gearing preferences when enabled.
+     */
+    public int[] getFrontTeethByGear() {
+        if (customGearing && customGearingFront != null) {
+            return customGearingFront;
+        }
+        if (shiftingInfo == null) {
+            return new int[0];
+        }
+        int gearCount = shiftingInfo.getFrontTeethPattern().getGearCount();
+        int[] teethByGear = new int[gearCount];
+        for (int gear = 1; gear <= gearCount; gear++) {
+            teethByGear[gear - 1] = shiftingInfo.getFrontTeethPattern().getTeethCount(gear);
+        }
+        return teethByGear;
+    }
+
 }
diff --git a/app/src/main/java/com/valterc/ki2/karoo/views/GearsProExtensionView.kt b/app/src/main/java/com/valterc/ki2/karoo/views/GearsProExtensionView.kt
