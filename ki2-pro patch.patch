@@ -0,0 +1,23299 @@
+diff --git a/.github/workflows/ki2-pro-release.yml b/.github/workflows/ki2-pro-release.yml
+new file mode 100644
+index 0000000..f47df2b
+--- /dev/null
++++ b/.github/workflows/ki2-pro-release.yml
+@@ -0,0 +1,67 @@
++# Ki2 Pro cloud build - works entirely from a phone.
++#
++# One-time setup in your fork (GitHub -> repo -> Settings -> Secrets and variables -> Actions):
++#   GH_USER        = your GitHub username
++#   GH_KEY         = a classic personal access token with read:packages scope
++#   S_NETWORK_KEY  = the base64 ANT network key (from the secrets.xml in the Ki2 Pro zip;
++#                    do NOT commit secrets.xml itself to a public repo)
++#
++# Then: GitHub -> Releases -> "Draft a new release" -> create tag (e.g. pro-1.0) -> Publish.
++# This workflow builds the APK and attaches ki2-pro.apk to that release.
++# Install it on the Karoo via the Hammerhead Companion App using the release asset URL.
++
++name: Ki2 Pro Release
++
++on:
++  release:
++    types: [published]
++  workflow_dispatch:
++
++permissions:
++  contents: write
++
++jobs:
++  build:
++    runs-on: ubuntu-latest
++    steps:
++      - uses: actions/checkout@v4
++
++      - name: Set up JDK 21
++        uses: actions/setup-java@v4
++        with:
++          java-version: '21'
++          distribution: 'temurin'
++          cache: gradle
++
++      - name: Inject secrets
++        env:
++          GH_USER: ${{ secrets.GH_USER }}
++          GH_KEY: ${{ secrets.GH_KEY }}
++          S_NETWORK_KEY: ${{ secrets.S_NETWORK_KEY }}
++        run: |
++          echo "<?xml version=\"1.0\" encoding=\"utf-8\"?><resources><string name=\"network_key\">${S_NETWORK_KEY}</string></resources>" > app/src/main/res/values/secrets.xml
++          echo "gpr.user=${GH_USER}" >> local.properties
++          echo "gpr.key=${GH_KEY}" >> local.properties
++          echo "VERSION_CODE=${{ github.run_number }}" >> local.properties
++          echo "VERSION_NAME=${{ github.ref_name }}" >> local.properties
++
++      - name: Build debug APK
++        run: |
++          chmod +x gradlew
++          ./gradlew assembleDebug
++
++      - name: Rename APK
++        run: cp app/build/outputs/apk/debug/app-debug.apk ki2-pro.apk
++
++      - name: Attach APK to release
++        if: github.event_name == 'release'
++        env:
++          GH_TOKEN: ${{ github.token }}
++        run: gh release upload ${{ github.event.release.tag_name }} ki2-pro.apk --clobber
++
++      - name: Upload artifact (manual runs)
++        if: github.event_name == 'workflow_dispatch'
++        uses: actions/upload-artifact@v4
++        with:
++          name: ki2-pro-apk
++          path: ki2-pro.apk
