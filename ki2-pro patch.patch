+    /**
+     * Get the configured wheel circumference in millimeters.
+     * Used by gear inches, speed at cadence and shift advice computations.
+     *
+     * @param context Ki2 application context. Cannot be a context generated from another package.
+     * @return Wheel circumference in millimeters.
+     */
+    public int getWheelCircumferenceMm(Context context) {
+        String value = getString(context.getString(R.string.preference_wheel_circumference), context.getString(R.string.default_preference_wheel_circumference));
+        try {
+            int parsed = Integer.parseInt(value.trim());
+            return parsed > 0 ? parsed : Integer.parseInt(context.getString(R.string.default_preference_wheel_circumference));
+        } catch (Exception e) {
+            return Integer.parseInt(context.getString(R.string.default_preference_wheel_circumference));
+        }
+    }
+
+    /**
+     * Get the configured target cadence in RPM. Used by shift advice.
+     *
+     * @param context Ki2 application context. Cannot be a context generated from another package.
+     * @return Target cadence in RPM.
+     */
+    public int getTargetCadence(Context context) {
+        String value = getString(context.getString(R.string.preference_target_cadence), context.getString(R.string.default_preference_target_cadence));
+        try {
+            int parsed = Integer.parseInt(value.trim());
+            return parsed > 0 ? parsed : Integer.parseInt(context.getString(R.string.default_preference_target_cadence));
+        } catch (Exception e) {
+            return Integer.parseInt(context.getString(R.string.default_preference_target_cadence));
+        }
+    }
+
+    private double getDoublePreference(Context context, int keyResource, int defaultResource) {
+        String value = getString(context.getString(keyResource), context.getString(defaultResource));
+        try {
+            double parsed = Double.parseDouble(value.trim().replace(',', '.'));
+            return parsed > 0 ? parsed : Double.parseDouble(context.getString(defaultResource));
+        } catch (Exception e) {
+            return Double.parseDouble(context.getString(defaultResource));
+        }
+    }
+
+    /**
+     * Total system mass (rider + bike + kit) in kilograms. Used by aero and pacing features.
+     */
+    public double getTotalMassKg(Context context) {
+        return getDoublePreference(context, R.string.preference_total_mass, R.string.default_preference_total_mass);
+    }
+
+    /**
+     * Rolling resistance coefficient. Used by aero and pacing features.
+     */
+    public double getCrr(Context context) {
+        return getDoublePreference(context, R.string.preference_crr, R.string.default_preference_crr);
+    }
+
+    /**
+     * Drivetrain efficiency (0-1). Used by aero and pacing features.
+     */
+    public double getDrivetrainEfficiency(Context context) {
+        return getDoublePreference(context, R.string.preference_drivetrain_efficiency, R.string.default_preference_drivetrain_efficiency);
+    }
+
+    /**
+     * Air density in kg/m3. Used by aero and pacing features.
+     */
+    public double getAirDensity(Context context) {
+        return getDoublePreference(context, R.string.preference_air_density, R.string.default_preference_air_density);
+    }
+
+    /**
+     * Calibrated CdA in m2. Used by the wind gauge and split predictor.
+     */
+    public double getCalibratedCda(Context context) {
+        return getDoublePreference(context, R.string.preference_calibrated_cda, R.string.default_preference_calibrated_cda);
+    }
+
+    /**
+     * Race distance in kilometers for the split predictor.
+     */
+    public double getRaceDistanceKm(Context context) {
+        return getDoublePreference(context, R.string.preference_race_distance, R.string.default_preference_race_distance);
+    }
+
+    /**
+     * Target split in minutes for the split predictor.
+     */
+    public double getTargetSplitMinutes(Context context) {
+        return getDoublePreference(context, R.string.preference_target_split, R.string.default_preference_target_split);
+    }
+
+    /**
+     * Carbohydrate intake target in grams per hour.
+     */
+    public int getCarbsTargetGramsPerHour(Context context) {
+        return (int) getDoublePreference(context, R.string.preference_carbs_per_hour, R.string.default_preference_carbs_per_hour);
+    }
+
+    /**
+     * Carbohydrate portion size (one gel / bar) in grams.
+     */
+    public int getCarbsPortionGrams(Context context) {
+        return (int) getDoublePreference(context, R.string.preference_carbs_portion, R.string.default_preference_carbs_portion);
+    }
