++++package com.valterc.ki2.karoo.shifting
++++
++++import kotlin.math.abs
++++
++++/**
++++ * Pure gear math: development, gear inches, speed/cadence predictions,
++++ * cross-chain detection and shift advice.
++++ *
++++ * Conventions (matching Ki2 / Shimano Di2):
++++ *  - Gear indices are 1-based.
++++ *  - Higher index = harder gear, for both front (bigger ring) and rear (smaller cog).
++++ *  - Teeth arrays are in gear order: element 0 corresponds to gear 1 (easiest).
++++ */
++++object GearMetrics {
++++
++++    const val DEFAULT_WHEEL_CIRCUMFERENCE_MM = 2096
++++    const val DEFAULT_TARGET_CADENCE = 90
++++    const val CADENCE_TOLERANCE = 4
++++    const val MIN_VALID_CADENCE = 20.0
++++
++++    enum class CrossChainState {
++++        NONE,
++++        WARN,
++++        SEVERE
++++    }
++++
++++    /**
++++     * Distance traveled per crank revolution, in meters.
++++     */
++++    fun developmentMeters(frontTeeth: Int, rearTeeth: Int, wheelCircumferenceMm: Int): Double {
++++        if (frontTeeth <= 0 || rearTeeth <= 0 || wheelCircumferenceMm <= 0) {
++++            return 0.0
++++        }
++++        return (frontTeeth.toDouble() / rearTeeth) * (wheelCircumferenceMm / 1000.0)
++++    }
++++
++++    /**
++++     * Classic gear inches: wheel diameter (inches) multiplied by gear ratio.
++++     */
++++    fun gearInches(frontTeeth: Int, rearTeeth: Int, wheelCircumferenceMm: Int): Double {
++++        if (frontTeeth <= 0 || rearTeeth <= 0 || wheelCircumferenceMm <= 0) {
++++            return 0.0
++++        }
++++        val wheelDiameterInches = (wheelCircumferenceMm / Math.PI) / 25.4
++++        return wheelDiameterInches * frontTeeth / rearTeeth
++++    }
++++
++++    /**
++++     * Speed in km/h at a given cadence in the given gear.
++++     */
++++    fun speedAtCadenceKmh(
++++        cadenceRpm: Double,
++++        frontTeeth: Int,
++++        rearTeeth: Int,
++++        wheelCircumferenceMm: Int
++++    ): Double {
++++        if (cadenceRpm <= 0) {
++++            return 0.0
++++        }
++++        return cadenceRpm * developmentMeters(frontTeeth, rearTeeth, wheelCircumferenceMm) * 60.0 / 1000.0
++++    }
++++
++++    /**
++++     * Detects cross-chaining.
++++     *
++++     * SEVERE: big ring + largest cog, or small ring + smallest cog.
++++     * WARN: big ring + one of the two largest cogs, or small ring + one of the two smallest cogs.
++++     */
++++    fun crossChainState(
++++        frontGear: Int,
++++        frontGearMax: Int,
++++        rearGear: Int,
++++        rearGearMax: Int
++++    ): CrossChainState {
++++        if (frontGearMax < 2 || frontGear <= 0 || rearGear <= 0 || rearGearMax <= 0) {
++++            return CrossChainState.NONE
++++        }
++++
++++        val onBigRing = frontGear == frontGearMax
++++        val onSmallRing = frontGear == 1
++++
++++        if (onBigRing) {
++++            if (rearGear == 1) return CrossChainState.SEVERE
++++            if (rearGear == 2) return CrossChainState.WARN
++++        }
++++
++++        if (onSmallRing) {
++++            if (rearGear == rearGearMax) return CrossChainState.SEVERE
++++            if (rearGear == rearGearMax - 1) return CrossChainState.WARN
++++        }
++++
++++        return CrossChainState.NONE
++++    }
++++
++++    /**
++++     * Result of shift advice computation.
++++     *
++++     * @param rearDelta Recommended change of rear gear index. Positive = shift to a
++++     *                  harder gear (smaller cog), negative = easier (bigger cog), 0 = stay.
++++     * @param predictedCadence Cadence predicted after applying the recommendation,
++++     *                         assuming constant wheel speed.
++++     * @param suggestFrontShift True when the cassette end is reached and cadence is
++++     *                          still outside the target band, i.e. a front shift is needed.
++++     */
++++    data class ShiftAdvice(
++++        val rearDelta: Int,
++++        val predictedCadence: Double,
++++        val suggestFrontShift: Boolean
++++    )
++++
++++    /**
++++     * Computes the rear-gear change (front kept constant) that would bring cadence
++++     * closest to the target at the current wheel speed.
++++     *
++++     * @param cadenceRpm Current measured cadence.
++++     * @param frontTeeth Teeth count of the current chainring.
++++     * @param rearGear Current rear gear index (1-based).
++++     * @param rearTeethByGear Rear teeth counts in gear order (element 0 = gear 1).
++++     * @param targetCadence Target cadence.
++++     * @param tolerance Acceptable deviation from target before advising a shift.
++++     */
++++    fun shiftAdvice(
++++        cadenceRpm: Double,
++++        frontTeeth: Int,
++++        rearGear: Int,
++++        rearTeethByGear: IntArray,
++++        targetCadence: Int,
++++        tolerance: Int = CADENCE_TOLERANCE
++++    ): ShiftAdvice? {
++++        if (cadenceRpm < MIN_VALID_CADENCE || frontTeeth <= 0 || targetCadence <= 0) {
++++            return null
++++        }
++++        val currentIndex = rearGear - 1
++++        if (currentIndex < 0 || currentIndex >= rearTeethByGear.size) {
++++            return null
++++        }
++++        val currentRearTeeth = rearTeethByGear[currentIndex]
++++        if (currentRearTeeth <= 0) {
++++            return null
++++        }
++++
++++        // Within the band already: no advice.
++++        if (abs(cadenceRpm - targetCadence) <= tolerance) {
++++            return ShiftAdvice(0, cadenceRpm, false)
++++        }
++++
++++        // Wheel speed is constant; predicted cadence in gear i is proportional to its cog size.
++++        var bestIndex = currentIndex
++++        var bestError = abs(cadenceRpm - targetCadence)
++++        var bestCadence = cadenceRpm
++++
++++        for (i in rearTeethByGear.indices) {
++++            val teeth = rearTeethByGear[i]
++++            if (teeth <= 0) {
++++                continue
++++            }
++++            val predicted = cadenceRpm * teeth / currentRearTeeth
++++            val error = abs(predicted - targetCadence)
++++            if (error < bestError - 0.01) {
++++                bestError = error
++++                bestIndex = i
++++                bestCadence = predicted
++++            }
++++        }
++++
++++        val delta = bestIndex - currentIndex
++++        val stillOutsideBand = bestError > tolerance
++++        // Only point at the front when the rear has nothing left to give:
++++        // rider first exhausts useful rear shifts, then gets the chainring hint.
++++        val suggestFront = stillOutsideBand && delta == 0
++++
++++        return ShiftAdvice(delta, bestCadence, suggestFront)
++++    }
++++}
