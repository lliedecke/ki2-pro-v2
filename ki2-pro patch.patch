++++/**
++++ * Projected bike split for the configured race distance, riding the rest of it
++++ * at the current Normalized Power on flat road with the calibrated CdA.
++++ * Green when under the target split, red when over.
++++ */
++++@OptIn(ExperimentalGlanceRemoteViewsApi::class)
++++class SplitPredictorDataType(private val extensionContext: Ki2ExtensionContext) :
++++    DataTypeImpl(extensionContext.extension, "DATATYPE_SPLIT_PREDICTOR") {
++++
++++    private val glance = GlanceRemoteViews()
++++
++++    private var preferencesView: PreferencesView? = null
++++    private var normalizedPower: Double = 0.0
++++
++++    override fun startView(context: Context, config: ViewConfig, emitter: ViewEmitter) {
++++        emitter.onNext(UpdateGraphicConfig(showHeader = true))
++++        emitter.onNext(ShowCustomStreamState(message = "", color = null))
++++
++++        val viewScope = CoroutineScope(Dispatchers.IO + Job())
++++
++++        val preferencesConsumer = Consumer<PreferencesView> { preferences ->
++++            preferencesView = preferences
++++            viewScope.launch { emitViewUpdate(context, config, emitter) }
++++        }
++++        extensionContext.serviceClient.registerPreferencesWeakListener(preferencesConsumer)
++++
++++        viewScope.launch {
++++            extensionContext.karooSystem.streamData(DataType.Type.NORMALIZED_POWER)
++++                .collect { streamState ->
++++                    normalizedPower =
++++                        (streamState as? StreamState.Streaming)?.dataPoint?.singleValue ?: 0.0
++++                    emitViewUpdate(context, config, emitter)
++++                }
++++        }
++++
++++        emitter.setCancellable {
++++            viewScope.cancel()
++++            extensionContext.serviceClient.unregisterPreferencesWeakListener(preferencesConsumer)
++++        }
++++    }
++++
++++    private suspend fun emitViewUpdate(context: Context, config: ViewConfig, emitter: ViewEmitter) {
++++        val preferences = preferencesView
++++
++++        val compositionResult = if (preferences == null || normalizedPower < 50) {
++++            glance.compose(context, DpSize.Unspecified) {
++++                Waiting(dataAlignment = config.alignment)
++++            }
++++        } else {
++++            val speed = RidePhysics.solveFlatSpeed(
++++                normalizedPower,
++++                preferences.getTotalMassKg(context),
++++                preferences.getCrr(context),
++++                preferences.getDrivetrainEfficiency(context),
++++                preferences.getAirDensity(context),
++++                preferences.getCalibratedCda(context)
++++            )
++++            val distanceMeters = preferences.getRaceDistanceKm(context) * 1000.0
++++            val targetSeconds = preferences.getTargetSplitMinutes(context) * 60.0
++++
++++            val (text, color) = if (speed < 1.0) {
++++                "…" to null
++++            } else {
++++                val seconds = distanceMeters / speed
++++                val hours = (seconds / 3600).toInt()
++++                val minutes = ((seconds % 3600) / 60).toInt()
++++                val formatted = String.format(Locale.US, "%d:%02d", hours, minutes)
++++                formatted to if (seconds <= targetSeconds) COLOR_GREEN else COLOR_RED
++++            }
++++
++++            glance.compose(context, DpSize.Unspecified) {
++++                TextView(text, dataAlignment = config.alignment, fontSize = config.textSize, textColor = color)
++++            }
++++        }
++++
++++        emitter.updateView(compositionResult.remoteViews)
++++    }
++++
++++    private companion object {
++++        val COLOR_GREEN = Color(0xFF34C759)
++++        val COLOR_RED = Color(0xFFFF453A)
++++    }
++++}
