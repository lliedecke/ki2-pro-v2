+++ * Carb balance versus the intake schedule: grams ahead (+) or behind (−).
+++ * Log a portion with the mapped Di2 switch action.
+++ */
+++@OptIn(ExperimentalGlanceRemoteViewsApi::class)
+++class FuelStateDataType(private val extensionContext: Ki2ExtensionContext) :
+++    DataTypeImpl(extensionContext.extension, "DATATYPE_FUEL_STATE") {
+++
+++    private val glance = GlanceRemoteViews()
+++
+++    override fun startView(context: Context, config: ViewConfig, emitter: ViewEmitter) {
+++        emitter.onNext(UpdateGraphicConfig(showHeader = true))
+++        emitter.onNext(ShowCustomStreamState(message = "", color = null))
+++
+++        val viewScope = CoroutineScope(Dispatchers.IO + Job())
+++        viewScope.launch {
+++            emitViewUpdate(context, config, emitter)
+++            extensionContext.fuelEngine.updates.collect {
+++                emitViewUpdate(context, config, emitter)
+++            }
+++        }
+++
+++        emitter.setCancellable { viewScope.cancel() }
+++    }
+++
+++    private suspend fun emitViewUpdate(context: Context, config: ViewConfig, emitter: ViewEmitter) {
+++        val engine = extensionContext.fuelEngine
+++
+++        var color: Color? = null
+++        val text = if (!engine.active()) {
+++            "—"
+++        } else {
+++            val balance = engine.balanceGrams()
+++            color = when {
+++                balance <= -engine.portionGrams() -> COLOR_RED
+++                balance >= 0 -> COLOR_GREEN
+++                else -> COLOR_AMBER
+++            }
+++            String.format(Locale.US, "%+.0fg", balance)
+++        }
+++
+++        val compositionResult = glance.compose(context, DpSize.Unspecified) {
+++            TextView(text, dataAlignment = config.alignment, fontSize = config.textSize, textColor = color)
+++        }
+++        emitter.updateView(compositionResult.remoteViews)
+++    }
+++
+++    private companion object {
+++        val COLOR_GREEN = Color(0xFF34C759)
+++        val COLOR_AMBER = Color(0xFFFF9F0A)
+++        val COLOR_RED = Color(0xFFFF453A)
+++    }
+++}
