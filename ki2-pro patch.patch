++++            viewScope.cancel()
++++            extensionContext.serviceClient.unregisterConnectionInfoWeakListener(connectionInfoListener)
++++            extensionContext.serviceClient.unregisterDevicePreferencesWeakListener(devicePreferencesConsumer)
++++            extensionContext.serviceClient.unregisterShiftingInfoWeakListener(shiftingInfoConsumer)
