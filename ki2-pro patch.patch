++++    fun startNewSegment() {
++++        currentCda()?.let { segmentHistory.add(it) }
++++        synchronized(segmentSamples) { segmentSamples.clear() }
++++        currentSegment += 1
++++        updates.tryEmit(Unit)
++++        extensionContext.audioManager.playSingleBeep()
++++    }
++++}
