+package com.valterc.ki2.karoo.powermetrics
+
+import com.valterc.ki2.data.preferences.PreferencesView
+import com.valterc.ki2.karoo.Ki2ExtensionContext
+import com.valterc.ki2.karoo.streamData
+import com.valterc.ki2.karoo.streamRideState
+import io.hammerhead.karooext.models.DataType
+import io.hammerhead.karooext.models.RideState
+import io.hammerhead.karooext.models.StreamState
+import kotlinx.coroutines.CoroutineScope
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.Job
+import kotlinx.coroutines.delay
+import kotlinx.coroutines.flow.MutableSharedFlow
+import kotlinx.coroutines.launch
+import java.util.function.Consumer
+
+/**
+ * Carbohydrate pacing coach.
+ *
+ * Tracks ride time against a grams-per-hour target, logs intake from a Di2
+ * switch action, and raises an audio nudge when the rider falls a full
+ * portion behind schedule.
+ */
+class FuelEngine(private val extensionContext: Ki2ExtensionContext) {
+
+    val updates = MutableSharedFlow<Unit>(extraBufferCapacity = 1)
+
+    private val scope = CoroutineScope(Dispatchers.IO + Job())
+
+    private val preferencesConsumer = Consumer<PreferencesView> { preferencesView ->
+        this.preferencesView = preferencesView
+    }
+
+    @Volatile
+    private var preferencesView: PreferencesView? = null
+
+    @Volatile
+    private var elapsedMs: Double = 0.0
+
+    @Volatile
+    var carbsEatenGrams: Double = 0.0
+        private set
+
+    private var lastNudgeTime: Long = 0
+
+    init {
+        extensionContext.serviceClient.registerPreferencesWeakListener(preferencesConsumer)
+
+        scope.launch {
+            extensionContext.karooSystem.streamData(DataType.Type.ELAPSED_TIME)
+                .collect {
+                    elapsedMs = (it as? StreamState.Streaming)?.dataPoint?.singleValue ?: elapsedMs
+                }
+        }
+        scope.launch {
+            extensionContext.karooSystem.streamRideState()
+                .collect { state ->
+                    if (state is RideState.Idle) {
+                        carbsEatenGrams = 0.0
+                        elapsedMs = 0.0
+                        lastNudgeTime = 0
+                        updates.tryEmit(Unit)
+                    }
+                }
+        }
+        scope.launch {
+            while (true) {
+                delay(if (active()) 1000 else 3000)
+                checkNudge()
+                updates.tryEmit(Unit)
+            }
+        }
+    }
+
+    private fun targetGramsPerHour(): Double =
+        preferencesView?.getCarbsTargetGramsPerHour(extensionContext.context)?.toDouble() ?: 90.0
+
+    fun portionGrams(): Double =
+        preferencesView?.getCarbsPortionGrams(extensionContext.context)?.toDouble() ?: 25.0
+
+    private fun elapsedHours(): Double = elapsedMs / 3_600_000.0
+
+    /** Grams ahead (+) or behind (−) the intake schedule. */
+    fun balanceGrams(): Double = carbsEatenGrams - targetGramsPerHour() * elapsedHours()
+
+    /** True once the ride clock is running. */
+    fun active(): Boolean = elapsedMs > 15_000
+
+    /**
+     * Seconds until the next portion is due (negative = overdue).
+     * The next portion is due when balance would reach −portion.
+     */
+    fun secondsToNextIntake(): Double {
+        val rate = targetGramsPerHour() / 3600.0
+        if (rate <= 0) return 0.0
+        return (balanceGrams() + portionGrams()) / rate
+    }
+
+    /** Logs one portion of carbs. Bound to a Di2 switch action. */
+    fun logIntake() {
+        carbsEatenGrams += portionGrams()
+        lastNudgeTime = System.currentTimeMillis()
+        updates.tryEmit(Unit)
+        extensionContext.audioManager.playSingleBeep()
+    }
+
+    private fun checkNudge() {
+        if (!active()) return
+        if (balanceGrams() > -portionGrams()) return
+        val now = System.currentTimeMillis()
+        if (now - lastNudgeTime < 5 * 60 * 1000) return
+        lastNudgeTime = now
+        extensionContext.audioManager.playDoubleBeep()
+    }
+}
diff --git a/app/src/main/java/com/valterc/ki2/karoo/powermetrics/RidePhysics.kt b/app/src/main/java/com/valterc/ki2/karoo/powermetrics/RidePhysics.kt
