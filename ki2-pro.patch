+++ b/app/src/main/java/com/valterc/ki2/karoo/powermetrics/AeroEngine.kt
@@ -0,0 +1,183 @@
+package com.valterc.ki2.karoo.powermetrics
+
+import com.valterc.ki2.data.preferences.PreferencesView
+import com.valterc.ki2.karoo.Ki2ExtensionContext
+import com.valterc.ki2.karoo.streamData
+import com.valterc.ki2.karoo.streamRideState
+import io.hammerhead.karooext.models.DataType
+import io.hammerhead.karooext.models.RideState
+import io.hammerhead.karooext.models.StreamState
+import kotlinx.coroutines.CoroutineScope
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.Job
+import kotlinx.coroutines.flow.MutableSharedFlow
+import kotlinx.coroutines.launch
+import java.util.ArrayDeque
+import java.util.concurrent.CopyOnWriteArrayList
+import java.util.function.Consumer
+import kotlin.math.abs
+
+/**
+ * Ride-long aero estimator.
+ *
+ * Continuously fuses power (3s), speed and grade into clean-condition CdA samples,
+ * grouped into test segments. A new segment is started from a Di2 switch action,
+ * enabling on-road A/B position testing. Also produces an apparent-wind estimate
+ * from the calibrated CdA preference.
+ */
+class AeroEngine(private val extensionContext: Ki2ExtensionContext) {
+
+    companion object {
+        private const val MIN_SPEED_MS = 6.9          // 25 km/h
+        private const val MIN_POWER_W = 80.0
+        private const val MAX_ACCEL_MS2 = 0.3
+        private const val MAX_GRADE = 0.04
+        private const val SEGMENT_SAMPLE_CAPACITY = 240
+        private const val ESTIMATE_WINDOW = 90
+        private const val WIND_WINDOW = 20
+        const val MIN_SAMPLES_FOR_ESTIMATE = 20
+    }
+
+    val updates = MutableSharedFlow<Unit>(extraBufferCapacity = 1)
+
+    private val scope = CoroutineScope(Dispatchers.IO + Job())
+
+    private val preferencesConsumer = Consumer<PreferencesView> { preferencesView ->
+        this.preferencesView = preferencesView
+    }
+
+    @Volatile
+    private var preferencesView: PreferencesView? = null
+
+    @Volatile private var power: Double = 0.0
+    @Volatile private var speed: Double = 0.0
+    @Volatile private var grade: Double = 0.0
+
+    private var lastSpeed: Double = 0.0
+    private var lastSampleTime: Long = 0
+
+    private val segmentSamples = ArrayDeque<Double>()
+    private val windSamples = ArrayDeque<Double>()
+
+    /** Median CdA of completed segments, oldest first. */
+    val segmentHistory = CopyOnWriteArrayList<Double>()
+
+    @Volatile
+    var currentSegment: Int = 1
+        private set
+
+    init {
+        extensionContext.serviceClient.registerPreferencesWeakListener(preferencesConsumer)
+
+        scope.launch {
+            extensionContext.karooSystem.streamData(DataType.Type.SMOOTHED_3S_AVERAGE_POWER)
+                .collect { power = it.valueOrZero() }
+        }
+        scope.launch {
+            extensionContext.karooSystem.streamData(DataType.Type.SPEED)
+                .collect {
+                    speed = it.valueOrZero()
+                    onSpeedTick()
+                }
+        }
+        scope.launch {
+            extensionContext.karooSystem.streamData(DataType.Type.ELEVATION_GRADE)
+                .collect { grade = it.valueOrZero() / 100.0 }
+        }
+        scope.launch {
+            extensionContext.karooSystem.streamRideState()
+                .collect { state -> if (state is RideState.Idle) resetForNewRide() }
+        }
+    }
+
+    private fun resetForNewRide() {
+        synchronized(segmentSamples) { segmentSamples.clear() }
+        synchronized(windSamples) { windSamples.clear() }
+        segmentHistory.clear()
+        currentSegment = 1
+        updates.tryEmit(Unit)
+    }
+
+    private fun StreamState.valueOrZero(): Double =
+        (this as? StreamState.Streaming)?.dataPoint?.singleValue ?: 0.0
+
+    private fun onSpeedTick() {
+        val now = System.currentTimeMillis()
+        val dt = (now - lastSampleTime) / 1000.0
+        val previousSpeed = lastSpeed
+        lastSpeed = speed
+        lastSampleTime = now
+
+        if (dt < 0.4 || dt > 3.0) return
+
+        val accel = (speed - previousSpeed) / dt
+        val preferences = preferencesView ?: return
+
+        val massKg = preferences.getTotalMassKg(extensionContext.context)
+        val crr = preferences.getCrr(extensionContext.context)
+        val efficiency = preferences.getDrivetrainEfficiency(extensionContext.context)
+        val airDensity = preferences.getAirDensity(extensionContext.context)
+
+        // Clean-condition gating
+        if (speed < MIN_SPEED_MS || power < MIN_POWER_W ||
+            abs(accel) > MAX_ACCEL_MS2 || abs(grade) > MAX_GRADE
+        ) {
+            return
+        }
+
+        RidePhysics.cdaSample(power, speed, grade, accel, massKg, crr, efficiency, airDensity)
+            ?.let { sample ->
+                synchronized(segmentSamples) {
+                    segmentSamples.addLast(sample)
+                    while (segmentSamples.size > SEGMENT_SAMPLE_CAPACITY) segmentSamples.removeFirst()
+                }
+            }
+
+        RidePhysics.windSample(
+            power, speed, grade, accel, massKg, crr, efficiency, airDensity,
+            preferences.getCalibratedCda(extensionContext.context)
+        )?.let { wind ->
+            synchronized(windSamples) {
+                windSamples.addLast(wind)
+                while (windSamples.size > WIND_WINDOW) windSamples.removeFirst()
+            }
+        }
+
+        updates.tryEmit(Unit)
+    }
+
+    /** Number of clean samples collected in the current segment. */
+    fun sampleCount(): Int = synchronized(segmentSamples) { segmentSamples.size }
+
+    /** Rolling CdA estimate of the current segment, or null while insufficient data. */
+    fun currentCda(): Double? {
+        synchronized(segmentSamples) {
+            if (segmentSamples.size < MIN_SAMPLES_FOR_ESTIMATE) return null
+            val window = segmentSamples.toList().takeLast(ESTIMATE_WINDOW)
+            return RidePhysics.median(window)
+        }
+    }
+
+    /** CdA of the previous segment, or null when this is the first. */
+    fun previousSegmentCda(): Double? = segmentHistory.lastOrNull()
+
+    /** Apparent wind (m/s, + = headwind) or null while insufficient data. */
+    fun currentWind(): Double? {
+        synchronized(windSamples) {
+            if (windSamples.size < 8) return null
+            return RidePhysics.median(windSamples)
+        }
+    }
+
+    /**
+     * Closes the current test segment (storing its estimate when valid)
+     * and starts a new one. Bound to a Di2 switch action.
+     */
+    fun startNewSegment() {
+        currentCda()?.let { segmentHistory.add(it) }
+        synchronized(segmentSamples) { segmentSamples.clear() }
+        currentSegment += 1
+        updates.tryEmit(Unit)
+        extensionContext.audioManager.playSingleBeep()
+    }
+}
