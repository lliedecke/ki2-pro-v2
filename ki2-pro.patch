+import kotlinx.coroutines.CoroutineScope
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.Job
+import kotlinx.coroutines.cancel
+import kotlinx.coroutines.launch
+import java.util.function.BiConsumer
+import java.util.function.Consumer
+
+/**
+ * Live shift advice based on target cadence.
+ *
+ * Shows the number of rear shifts (at current wheel speed) that would bring
+ * cadence closest to the configured target:
+ *  - "▲2": shift 2 gears harder (smaller cogs)
+ *  - "▼1": shift 1 gear easier (bigger cog)
+ *  - "✓": cadence within the target band
+ *  - "F▲"/"F▼": rear cassette exhausted, change chainring
+ *  - "–": no valid cadence (coasting or no sensor)
+ */
+@OptIn(ExperimentalGlanceRemoteViewsApi::class)
+class ShiftAdviceDataType(private val extensionContext: Ki2ExtensionContext) :
+    DataTypeImpl(extensionContext.extension, "DATATYPE_SHIFT_ADVICE") {
+
+    private val glance = GlanceRemoteViews()
+    private var lastRendered: Pair<String, Color?>? = null
+    private var connectionInfo: ConnectionInfo? = null
+    private var preferencesView: PreferencesView? = null
+    private var shiftingGearingHelper = ShiftingGearingHelper(extensionContext.context)
+    private var cadence: Double = 0.0
+
+    override fun startView(context: Context, config: ViewConfig, emitter: ViewEmitter) {
+        emitter.onNext(UpdateGraphicConfig(showHeader = true))
+        emitter.onNext(ShowCustomStreamState(message = "", color = null))
+
+        val viewScope = CoroutineScope(Dispatchers.IO + Job())
+
+        val connectionInfoListener =
+            BiConsumer<DeviceId, ConnectionInfo> { _: DeviceId, connectionInfo: ConnectionInfo ->
+                this.connectionInfo = connectionInfo
+                viewScope.launch { emitViewUpdate(context, config, emitter) }
+            }
+
+        val devicePreferencesConsumer =
+            BiConsumer<DeviceId, DevicePreferencesView> { _: DeviceId, devicePreferences: DevicePreferencesView ->
+                shiftingGearingHelper.setDevicePreferences(devicePreferences)
+                viewScope.launch { emitViewUpdate(context, config, emitter) }
+            }
+
+        val shiftingInfoConsumer =
+            BiConsumer<DeviceId, ShiftingInfo> { _: DeviceId, shiftingInfo: ShiftingInfo ->
+                shiftingGearingHelper.setShiftingInfo(shiftingInfo)
+                viewScope.launch { emitViewUpdate(context, config, emitter) }
+            }
+
+        val preferencesConsumer =
+            Consumer<PreferencesView> { preferencesView: PreferencesView ->
+                this.preferencesView = preferencesView
+                viewScope.launch { emitViewUpdate(context, config, emitter) }
+            }
+
+        extensionContext.serviceClient.registerConnectionInfoWeakListener(connectionInfoListener)
+        extensionContext.serviceClient.registerDevicePreferencesWeakListener(devicePreferencesConsumer)
+        extensionContext.serviceClient.registerShiftingInfoWeakListener(shiftingInfoConsumer)
+        extensionContext.serviceClient.registerPreferencesWeakListener(preferencesConsumer)
+
+        viewScope.launch {
+            extensionContext.karooSystem.streamData(DataType.Type.CADENCE)
+                .collect { streamState ->
+                    cadence = when (streamState) {
+                        is StreamState.Streaming -> streamState.dataPoint.singleValue ?: 0.0
+                        else -> 0.0
+                    }
+                    emitViewUpdate(context, config, emitter)
+                }
+        }
+
+        emitter.setCancellable {
+            viewScope.cancel()
+            extensionContext.serviceClient.unregisterConnectionInfoWeakListener(connectionInfoListener)
+            extensionContext.serviceClient.unregisterDevicePreferencesWeakListener(devicePreferencesConsumer)
+            extensionContext.serviceClient.unregisterShiftingInfoWeakListener(shiftingInfoConsumer)
+            extensionContext.serviceClient.unregisterPreferencesWeakListener(preferencesConsumer)
+        }
+    }
+
+    private suspend fun emitViewUpdate(context: Context, config: ViewConfig, emitter: ViewEmitter) {
+        val compositionResult =
+            if (connectionInfo?.isConnected == true && shiftingGearingHelper.hasValidGearingInfo()) {
+                val targetCadence = preferencesView?.getTargetCadence(context)
+                    ?: GearMetrics.DEFAULT_TARGET_CADENCE
+
+                val advice = GearMetrics.shiftAdvice(
+                    cadence,
+                    shiftingGearingHelper.frontGearTeethCount,
+                    shiftingGearingHelper.rearGear,
+                    shiftingGearingHelper.rearTeethByGear,
+                    targetCadence
+                )
+
+                val (text, color) = adviceDisplay(advice, targetCadence)
+                if (text to color == lastRendered) return
+                lastRendered = text to color
+
+                glance.compose(context, DpSize.Unspecified) {
+                    TextView(
+                        text,
+                        dataAlignment = config.alignment,
+                        fontSize = config.textSize,
+                        textColor = color
+                    )
+                }
+            } else if (connectionInfo?.isClosed == true) {
+                lastRendered = null
+                glance.compose(context, DpSize.Unspecified) {
+                    NotAvailable(dataAlignment = config.alignment)
+                }
+            } else {
+                lastRendered = null
+                glance.compose(context, DpSize.Unspecified) {
+                    Waiting(dataAlignment = config.alignment)
+                }
+            }
+
+        emitter.updateView(compositionResult.remoteViews)
+    }
+
+    private fun adviceDisplay(
+        advice: GearMetrics.ShiftAdvice?,
+        targetCadence: Int
+    ): Pair<String, Color?> {
+        if (advice == null) {
+            return "–" to null
+        }
+
+        if (advice.suggestFrontShift) {
+            val frontShiftUp = cadence > targetCadence
+            val frontAvailable = if (frontShiftUp) {
+                shiftingGearingHelper.frontGear < shiftingGearingHelper.frontGearMax
+            } else {
+                shiftingGearingHelper.frontGear > 1
+            }
+            if (!frontAvailable) {
+                // Gearing exhausted in this direction: nothing actionable.
+                return "–" to null
+            }
+            return (if (frontShiftUp) "F▲" else "F▼") to COLOR_AMBER
+        }
+
+        return when {
+            advice.rearDelta > 0 -> "▲${advice.rearDelta}" to COLOR_AMBER
+            advice.rearDelta < 0 -> "▼${-advice.rearDelta}" to COLOR_AMBER
+            else -> "✓" to COLOR_GREEN
+        }
+    }
+
+    private companion object {
+        val COLOR_GREEN = Color(0xFF34C759)
+        val COLOR_AMBER = Color(0xFFFF9F0A)
+    }
+}
