@@ -0,0 +1,88 @@
+package com.valterc.ki2.karoo.powermetrics
+
+import kotlin.math.abs
+import kotlin.math.max
+import kotlin.math.sqrt
+
+/**
+ * Pure cycling physics used by the Aero, Wind and Split Predictor features.
+ *
+ * Model (still air unless wind is being solved):
+ *   P_wheel = eta * P_pedal
+ *   P_wheel = 0.5 * rho * CdA * vAir^2 * v  +  Crr * m * g * v  +  m * g * grade * v  +  m * a * v
+ */
+object RidePhysics {
+
+    const val GRAVITY = 9.80665
+
+    /** Non-aero power at ground speed v: rolling + gravity + acceleration. */
+    fun nonAeroPower(
+        v: Double, grade: Double, accel: Double,
+        massKg: Double, crr: Double
+    ): Double {
+        return crr * massKg * GRAVITY * v +
+                massKg * GRAVITY * grade * v +
+                massKg * accel * v
+    }
+
+    /**
+     * Single-sample CdA estimate assuming still air.
+     * Returns null when the aero share of power is non-physical.
+     */
+    fun cdaSample(
+        powerW: Double, v: Double, grade: Double, accel: Double,
+        massKg: Double, crr: Double, drivetrainEfficiency: Double, airDensity: Double
+    ): Double? {
+        if (v <= 0.5) return null
+        val aeroPower = drivetrainEfficiency * powerW - nonAeroPower(v, grade, accel, massKg, crr)
+        if (aeroPower <= 0) return null
+        val cda = aeroPower / (0.5 * airDensity * v * v * v)
+        return if (cda in 0.05..0.8) cda else null
+    }
+
+    /**
+     * Apparent-wind estimate for a known CdA.
+     * Positive = headwind component, negative = tailwind (or drafting).
+     */
+    fun windSample(
+        powerW: Double, v: Double, grade: Double, accel: Double,
+        massKg: Double, crr: Double, drivetrainEfficiency: Double,
+        airDensity: Double, cda: Double
+    ): Double? {
+        if (v <= 0.5 || cda <= 0) return null
+        val aeroPower = drivetrainEfficiency * powerW - nonAeroPower(v, grade, accel, massKg, crr)
+        val vAirSq = max(0.0, aeroPower) / (0.5 * airDensity * cda * v)
+        return sqrt(vAirSq) - v
+    }
+
+    /**
+     * Solve steady flat-road speed (m/s) for a given pedal power via Newton iteration.
+     */
+    fun solveFlatSpeed(
+        powerW: Double, massKg: Double, crr: Double,
+        drivetrainEfficiency: Double, airDensity: Double, cda: Double
+    ): Double {
+        if (powerW < 30 || cda <= 0) return 0.0
+        val pw = drivetrainEfficiency * powerW
+        val kAero = 0.5 * airDensity * cda
+        val kRoll = crr * massKg * GRAVITY
+        var v = 9.0
+        repeat(24) {
+            val f = kAero * v * v * v + kRoll * v - pw
+            val fp = 3 * kAero * v * v + kRoll
+            val step = f / fp
+            v -= step
+            if (v < 1.0) v = 1.0
+            if (abs(step) < 1e-4) return v
+        }
+        return v
+    }
+
+    /** Median of a collection; 0.0 when empty. */
+    fun median(values: Collection<Double>): Double {
+        if (values.isEmpty()) return 0.0
+        val sorted = values.sorted()
+        val mid = sorted.size / 2
+        return if (sorted.size % 2 == 1) sorted[mid] else (sorted[mid - 1] + sorted[mid]) / 2.0
+    }
+}
diff --git a/app/src/main/java/com/valterc/ki2/karoo/shifting/GearMetrics.kt b/app/src/main/java/com/valterc/ki2/karoo/shifting/GearMetrics.kt
