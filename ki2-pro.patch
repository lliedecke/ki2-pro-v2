 }
diff --git a/app/src/main/java/com/valterc/ki2/karoo/views/GearsProExtensionView.kt b/app/src/main/java/com/valterc/ki2/karoo/views/GearsProExtensionView.kt
new file mode 100644
index 0000000..ed50f7d
--- /dev/null
+++ b/app/src/main/java/com/valterc/ki2/karoo/views/GearsProExtensionView.kt
@@ -0,0 +1,351 @@
+package com.valterc.ki2.karoo.views
+
+import android.annotation.SuppressLint
+import android.text.SpannableStringBuilder
+import android.util.TypedValue
+import android.text.Spanned
+import android.text.style.ForegroundColorSpan
+import android.text.style.RelativeSizeSpan
+import android.view.LayoutInflater
+import android.view.View
+import android.widget.TextView
+import androidx.constraintlayout.widget.ConstraintLayout
+import com.valterc.ki2.R
+import com.valterc.ki2.data.connection.ConnectionInfo
+import com.valterc.ki2.data.connection.ConnectionStatus
+import com.valterc.ki2.data.device.BatteryInfo
+import com.valterc.ki2.data.device.DeviceId
+import com.valterc.ki2.data.preferences.PreferencesView
+import com.valterc.ki2.data.preferences.device.DevicePreferencesView
+import com.valterc.ki2.data.shifting.ShiftingInfo
+import com.valterc.ki2.karoo.Ki2ExtensionContext
+import com.valterc.ki2.karoo.shifting.GearMetrics
+import com.valterc.ki2.karoo.shifting.ShiftingGearingHelper
+import com.valterc.ki2.karoo.streamData
+import com.valterc.ki2.views.GearsView
+import com.valterc.ki2.views.battery.BatteryView
+import io.hammerhead.karooext.models.DataType
+import io.hammerhead.karooext.models.StreamState
+import io.hammerhead.karooext.models.ViewConfig
+import kotlinx.coroutines.CoroutineScope
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.Job
+import kotlinx.coroutines.cancel
+import kotlinx.coroutines.launch
+import java.util.Locale
+import java.util.function.BiConsumer
+import java.util.function.Consumer
+
+/**
+ * "Gears Pro": a large, glanceable all-in-one gear display.
+ *
+ *  - Auto-sizing gear numerals (2 | 7), readable at speed in any field size
+ *  - Inline shift-advice chevron (▲2 / ▼1 / F▲) driven by live cadence vs target
+ *  - Teeth combination and development (36 × 19 · 8.2 m)
+ *  - Gear position bar
+ *  - Cross-chain warning: numerals and gear bar turn amber (warn) / red (severe)
+ *  - Di2 battery pill with low/critical coloring
+ */
+class GearsProExtensionView(context: Ki2ExtensionContext) : Ki2ExtensionView(context) {
+
+    private val devicePreferencesConsumer =
+        BiConsumer<DeviceId, DevicePreferencesView> { _: DeviceId?, devicePreferences: DevicePreferencesView? ->
+            shiftingGearingHelper.setDevicePreferences(devicePreferences)
+            updateView()
+        }
+
+    private val connectionInfoConsumer =
+        BiConsumer { _: DeviceId?, connectionInfo: ConnectionInfo ->
+            connectionStatus = connectionInfo.connectionStatus
+            updateView()
+        }
+
+    private val shiftingInfoConsumer =
+        BiConsumer { _: DeviceId?, shiftingInfo: ShiftingInfo? ->
+            shiftingGearingHelper.setShiftingInfo(shiftingInfo)
+            updateView()
+        }
+
+    private val batteryInfoConsumer =
+        BiConsumer { _: DeviceId?, batteryInfo: BatteryInfo? ->
+            this.batteryInfo = batteryInfo
+            updateView()
+        }
+
+    private val preferencesConsumer =
+        Consumer { preferencesView: PreferencesView? ->
+            this.preferencesView = preferencesView
+            updateView()
+        }
+
+    private val shiftingGearingHelper = ShiftingGearingHelper(context.context)
+    private var connectionStatus: ConnectionStatus? = null
+    private var batteryInfo: BatteryInfo? = null
+    private var preferencesView: PreferencesView? = null
+    private var cadence: Double = 0.0
+    private var viewScope: CoroutineScope? = null
+    private var cellWidth: Int = 0
+    private var baseMainTextSizePx: Float = 0f
+    private var lastSignature: String? = null
+
+    private var textViewWaitingForData: TextView? = null
+    private var textViewMain: TextView? = null
+    private var textViewTeeth: TextView? = null
+    private var textViewBattery: TextView? = null
+    private var batteryView: BatteryView? = null
+    private var gearsView: GearsView? = null
+
+    init {
+        serviceClient.registerDevicePreferencesWeakListener(devicePreferencesConsumer)
+        serviceClient.registerConnectionInfoWeakListener(connectionInfoConsumer)
+        serviceClient.registerShiftingInfoWeakListener(shiftingInfoConsumer)
+        serviceClient.registerBatteryInfoWeakListener(batteryInfoConsumer)
+        serviceClient.registerPreferencesWeakListener(preferencesConsumer)
+
+        val scope = CoroutineScope(Dispatchers.Main + Job())
+        viewScope = scope
+        scope.launch {
+            extensionContext.karooSystem.streamData(DataType.Type.CADENCE)
+                .collect { streamState ->
+                    cadence = when (streamState) {
+                        is StreamState.Streaming -> streamState.dataPoint.singleValue ?: 0.0
+                        else -> 0.0
+                    }
+                    updateView()
+                }
+        }
+    }
+
+    override fun dispose() {
+        super.dispose()
+        viewScope?.cancel()
+        viewScope = null
+        serviceClient.unregisterDevicePreferencesWeakListener(devicePreferencesConsumer)
+        serviceClient.unregisterConnectionInfoWeakListener(connectionInfoConsumer)
+        serviceClient.unregisterShiftingInfoWeakListener(shiftingInfoConsumer)
+        serviceClient.unregisterBatteryInfoWeakListener(batteryInfoConsumer)
+        serviceClient.unregisterPreferencesWeakListener(preferencesConsumer)
+    }
+
+    @SuppressLint("InflateParams")
+    override fun createView(layoutInflater: LayoutInflater, viewConfig: ViewConfig): View {
+        val inflatedView = layoutInflater.inflate(R.layout.view_karoo_gears_pro, null)
+
+        val params = ConstraintLayout.LayoutParams(
+            ConstraintLayout.LayoutParams.MATCH_CONSTRAINT,
+            ConstraintLayout.LayoutParams.MATCH_CONSTRAINT
+        )
+        params.matchConstraintMinWidth = viewConfig.viewSize.first
+        params.matchConstraintMinHeight = viewConfig.viewSize.second
+
+        inflatedView.layoutParams = params
+        inflatedView.forceLayout()
+        inflatedView.measure(
+            View.MeasureSpec.makeMeasureSpec(viewConfig.viewSize.first, View.MeasureSpec.EXACTLY),
+            View.MeasureSpec.makeMeasureSpec(viewConfig.viewSize.second, View.MeasureSpec.EXACTLY)
+        )
+        inflatedView.layout(0, 0, inflatedView.measuredWidth, inflatedView.measuredHeight)
+
+        textViewWaitingForData =
+            inflatedView.findViewById(R.id.textview_karoo_gears_pro_waiting_for_data)
+        textViewMain = inflatedView.findViewById(R.id.textview_karoo_gears_pro_main)
+        textViewTeeth = inflatedView.findViewById(R.id.textview_karoo_gears_pro_teeth)
+        textViewBattery = inflatedView.findViewById(R.id.textview_karoo_gears_pro_battery)
+        batteryView = inflatedView.findViewById(R.id.batteryview_karoo_gears_pro)
+        gearsView = inflatedView.findViewById(R.id.gearsview_karoo_gears_pro)
+
+        // Deterministic text sizing from the actual field cell height:
+        // clean and readable at every field size, independent of autosize machinery.
+        val cellHeight = viewConfig.viewSize.second.toFloat()
+        cellWidth = viewConfig.viewSize.first
+        baseMainTextSizePx = (cellHeight * 0.40f).coerceAtLeast(24f)
+        textViewMain?.setTextSize(TypedValue.COMPLEX_UNIT_PX, baseMainTextSizePx)
+        textViewTeeth?.setTextSize(TypedValue.COMPLEX_UNIT_PX, (cellHeight * 0.15f).coerceIn(14f, 40f))
+
+        if (karooTheme == KarooTheme.WHITE) {
+            textViewWaitingForData?.setTextColor(context.getColor(R.color.hh_black))
+            textViewMain?.setTextColor(context.getColor(R.color.hh_black))
+            gearsView?.setUnselectedGearBorderColor(context.getColor(R.color.hh_gears_border_light))
+            gearsView?.setSelectedGearColor(context.getColor(R.color.hh_gears_active_light))
+        } else {
+            textViewWaitingForData?.setTextColor(context.getColor(R.color.white))
+            textViewMain?.setTextColor(context.getColor(R.color.white))
+            gearsView?.setUnselectedGearBorderColor(context.getColor(R.color.hh_gears_border_dark))
+            gearsView?.setSelectedGearColor(context.getColor(R.color.hh_gears_active_dark))
+        }
+
+        updateView()
+        return inflatedView
+    }
+
+    private fun updateView() {
+        val gearsView = gearsView ?: return
+        val textViewMain = textViewMain ?: return
+        val textViewTeeth = textViewTeeth ?: return
+        val textViewBattery = textViewBattery ?: return
+        val batteryView = batteryView ?: return
+        val textViewWaitingForData = textViewWaitingForData ?: return
+        val preferencesView = preferencesView
+
+        // ---- Gather everything first (no view mutation yet) ----
+        val waiting = connectionStatus != ConnectionStatus.ESTABLISHED ||
+                shiftingGearingHelper.hasInvalidGearingInfo() || preferencesView == null
+
+        if (waiting) {
+            if (lastSignature == "WAITING") return
+            lastSignature = "WAITING"
+            gearsView.visibility = View.INVISIBLE
+            textViewMain.visibility = View.INVISIBLE
+            textViewTeeth.visibility = View.INVISIBLE
+            textViewBattery.visibility = View.INVISIBLE
+            batteryView.visibility = View.INVISIBLE
+            textViewWaitingForData.visibility = View.VISIBLE
+            viewUpdated()
+            return
+        }
+        requireNotNull(preferencesView)
+
+        val frontGear = shiftingGearingHelper.frontGear
+        val frontGearMax = shiftingGearingHelper.frontGearMax
+        val rearGear = shiftingGearingHelper.rearGear
+        val rearGearMax = shiftingGearingHelper.rearGearMax
+        val targetCadence = preferencesView.getTargetCadence(context)
+
+        val crossChain =
+            GearMetrics.crossChainState(frontGear, frontGearMax, rearGear, rearGearMax)
+
+        val advice = GearMetrics.shiftAdvice(
+            cadence,
+            shiftingGearingHelper.frontGearTeethCount,
+            rearGear,
+            shiftingGearingHelper.rearTeethByGear,
+            targetCadence
+        )
+        val frontShiftUp = cadence > targetCadence
+        val frontAvailable = if (frontShiftUp) frontGear < frontGearMax else frontGear > 1
+        val adviceText = when {
+            advice == null -> null
+            advice.suggestFrontShift && frontAvailable -> if (frontShiftUp) "F\u25b2" else "F\u25bc"
+            advice.rearDelta > 0 -> "\u25b2${advice.rearDelta}"
+            advice.rearDelta < 0 -> "\u25bc${-advice.rearDelta}"
+            else -> null
+        }
+
+        val teethText = if (shiftingGearingHelper.hasGearSizes()) {
+            val development = GearMetrics.developmentMeters(
+                shiftingGearingHelper.frontGearTeethCount,
+                shiftingGearingHelper.rearGearTeethCount,
+                preferencesView.getWheelCircumferenceMm(context)
+            )
+            String.format(
+                Locale.getDefault(),
+                "%d \u00d7 %d  \u00b7  %.1f m",
+                shiftingGearingHelper.frontGearTeethCount,
+                shiftingGearingHelper.rearGearTeethCount,
+                development
+            )
+        } else {
+            ""
+        }
+
+        val batteryValue = batteryInfo?.value
+
+        // ---- Skip the redraw entirely when nothing visible changed ----
+        val signature =
+            "$frontGear/$frontGearMax|$rearGear/$rearGearMax|$crossChain|$adviceText|$teethText|$batteryValue"
+        if (signature == lastSignature) return
+        lastSignature = signature
+
+        // ---- Mutate views ----
+        textViewWaitingForData.visibility = View.INVISIBLE
+        gearsView.visibility = View.VISIBLE
+        textViewMain.visibility = View.VISIBLE
+        textViewTeeth.visibility = View.VISIBLE
+
+        gearsView.setGears(frontGearMax, frontGear, rearGearMax, rearGear)
+
+        val defaultNumeralColor = if (karooTheme == KarooTheme.WHITE) {
+            context.getColor(R.color.hh_black)
+        } else {
+            context.getColor(R.color.white)
+        }
+        val numeralColor = when (crossChain) {
+            GearMetrics.CrossChainState.SEVERE -> context.getColor(R.color.hh_red_600)
+            GearMetrics.CrossChainState.WARN -> context.getColor(R.color.hh_yellow_darker)
+            GearMetrics.CrossChainState.NONE -> defaultNumeralColor
+        }
+        gearsView.selectedGearColor = when (crossChain) {
+            GearMetrics.CrossChainState.SEVERE -> context.getColor(R.color.hh_red_600)
+            GearMetrics.CrossChainState.WARN -> context.getColor(R.color.hh_yellow_darker)
+            GearMetrics.CrossChainState.NONE -> preferencesView.getAccentColor(context, karooTheme)
+        }
+
+        val separatorColor = context.getColor(R.color.hh_light_grey)
+        val adviceColor = context.getColor(R.color.hh_yellow_darker)
+        val main = SpannableStringBuilder()
+
+        var start = main.length
+        main.append(frontGear.toString())
+        main.setSpan(ForegroundColorSpan(numeralColor), start, main.length, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
+
+        start = main.length
+        main.append(" | ")
+        main.setSpan(ForegroundColorSpan(separatorColor), start, main.length, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
+        main.setSpan(RelativeSizeSpan(0.6f), start, main.length, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
+
+        start = main.length
+        main.append(rearGear.toString())
+        main.setSpan(ForegroundColorSpan(numeralColor), start, main.length, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
+
+        if (adviceText != null) {
+            start = main.length
+            main.append("  ").append(adviceText)
+            main.setSpan(ForegroundColorSpan(adviceColor), start, main.length, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
+            main.setSpan(RelativeSizeSpan(0.55f), start, main.length, Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
+        }
+
+        // Fit-to-width: start from the base size, shrink only when needed.
+        textViewMain.setTextSize(TypedValue.COMPLEX_UNIT_PX, baseMainTextSizePx)
+        textViewMain.text = main
+        if (cellWidth > 0) {
+            val needed = textViewMain.paint.measureText(main.toString())
+            val maxWidth = cellWidth * 0.92f
+            if (needed > maxWidth) {
+                textViewMain.setTextSize(
+                    TypedValue.COMPLEX_UNIT_PX,
+                    baseMainTextSizePx * maxWidth / needed
+                )
+            }
+        }
+
+        textViewTeeth.text = teethText
+
+        // Di2 battery pill
+        batteryInfo?.let { batteryInfo ->
+            batteryView.visibility = View.VISIBLE
+            textViewBattery.visibility = View.VISIBLE
+            batteryView.value = batteryInfo.value.toFloat() / 100
+            textViewBattery.text =
+                context.getString(R.string.text_param_percentage, batteryInfo.value)
+
+            val criticalBatteryLevel = preferencesView.getBatteryLevelCritical(context)
+            val lowBatteryLevel = preferencesView.getBatteryLevelLow(context)
+
+            if (criticalBatteryLevel != null && batteryInfo.value <= criticalBatteryLevel) {
+                batteryView.setForegroundColor(context.getColor(R.color.hh_red))
+                batteryView.setBorderColor(context.getColor(R.color.hh_red))
+            } else if (lowBatteryLevel != null && batteryInfo.value <= lowBatteryLevel) {
+                batteryView.setForegroundColor(context.getColor(R.color.hh_yellow_darker))
+                batteryView.setBorderColor(context.getColor(R.color.hh_yellow_darker))
+            } else {
+                batteryView.setForegroundColor(context.getColor(R.color.hh_success_green_600))
+                batteryView.setBorderColor(context.getColor(R.color.hh_success_green_600))
+            }
+        } ?: run {
+            batteryView.visibility = View.INVISIBLE
+            textViewBattery.visibility = View.INVISIBLE
+        }
+
+        viewUpdated()
+    }
+}
