+        // Ride metrics / Aero & Fuel: force a numeric keyboard for these EditTextPreference
+        // fields instead of the default full keyboard, matching the rest of the app's
+        // touch-friendly controls. AndroidX EditTextPreference does not honor
+        // android:inputType from XML, so it must be bound here.
+        final int integerInput = InputType.TYPE_CLASS_NUMBER;
+        final int decimalInput = InputType.TYPE_CLASS_NUMBER | InputType.TYPE_NUMBER_FLAG_DECIMAL;
+
+        setupNumericField(R.string.preference_wheel_circumference, integerInput);
+        setupNumericField(R.string.preference_target_cadence, integerInput);
+        setupNumericField(R.string.preference_total_mass, decimalInput);
+        setupNumericField(R.string.preference_crr, decimalInput);
+        setupNumericField(R.string.preference_drivetrain_efficiency, decimalInput);
+        setupNumericField(R.string.preference_air_density, decimalInput);
+        setupNumericField(R.string.preference_calibrated_cda, decimalInput);
+        setupNumericField(R.string.preference_race_distance, decimalInput);
+        setupNumericField(R.string.preference_target_split, decimalInput);
+        setupNumericField(R.string.preference_carbs_per_hour, integerInput);
+        setupNumericField(R.string.preference_carbs_portion, integerInput);
+    }
+
+    private void setupNumericField(int keyResId, int inputType) {
+        Preference preference = findPreference(getString(keyResId));
+        if (!(preference instanceof EditTextPreference)) {
+            return;
+        }
+
+        ((EditTextPreference) preference).setOnBindEditTextListener(editText -> {
+            editText.setInputType(inputType);
+            editText.setSingleLine(true);
+            if (editText.getText() != null) {
+                editText.setSelection(editText.getText().length());
+            }
+        });
     }
 
